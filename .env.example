# Copy to .env and fill in. Never commit .env.

# --- Telegram (from https://my.telegram.org + @BotFather) ---
API_ID=12345
API_HASH=0123456789abcdef0123456789abcdef
BOT_TOKEN=123456:ABC-DEF_your-bot-token-here

# --- Datastores ---
# Local dev (docker compose up postgres redis) - containers publish on
# 5433/6380 so they never clash with a natively installed Postgres/Redis:
DATABASE_URL=postgresql+asyncpg://nowaybot:nowaybot@localhost:5433/nowaybot
REDIS_URL=redis://localhost:6380/0
# Inside docker compose the worker/bot containers override these to use the
# service hostnames (postgres/redis) - see docker-compose.yml.

# --- Channels & admins ---
# Channels the worker indexes. Bot must be ADMIN in each.
# Comma-separated or JSON list. Channel ids are negative (-100...).
SOURCE_CHANNEL_IDS=-1001234567890
# Telegram user ids allowed to run /index and other admin commands.
ADMIN_IDS=123456789

# --- Indexing tuning (defaults shown; all optional) ---
# Messages fetched per get_messages batch during backfill (max 200).
BACKFILL_BATCH_SIZE=100
# Base delay in seconds between backfill batches (adaptive pacer floor).
BASE_BATCH_DELAY=2.5
# pg_trgm similarity threshold for fuzzy title resolution (0..1).
FUZZY_THRESHOLD=0.45
# Seconds between worker polls of index_progress for new jobs.
JOB_POLL_INTERVAL=15

# --- Search tuning (defaults shown; all optional) ---
# Results per page shown to the user.
SEARCH_PAGE_SIZE=10
# Seconds a cached result set / pagination cursor stays valid in Redis.
SEARCH_CACHE_TTL=300
# Hard cap on matches fetched per query (exact + fuzzy combined).
SEARCH_MAX_RESULTS=50
# Trigram floor for "did you mean" suggestions. Looser than the search
# threshold on purpose: this only runs after search found nothing, where
# a loose guess beats a dead end. It never affects what search returns.
SUGGEST_THRESHOLD=0.15
# How many DISTINCT users must ask for the same missing title within 24h
# before it is reported to the log channel. Minimum 2.
MISSING_THRESHOLD=3

# --- Log channel, shortlink gate, premium ---
# These are NOT env vars: an admin sets them from chat so they take
# effect in both the bot and the worker with no redeploy.
#   /setlog <channel_id>            where events are logged
#   /setshortener <api_token> [url] AroLinks-style shortener
#   /shortlink on|off               gate file delivery behind an unlock
#   /setaccesshours <n>             how long one unlock lasts (default 4)
#   /addpremium <user_id> <6h|30d|1y>
#   /showconfig                     current values (token masked)

# --- Group keyword filters (defaults shown; all optional) ---
# Seconds a group's keyword set stays cached in Redis. Only a backstop:
# every /filter and /stop clears its group's cache immediately.
FILTER_CACHE_TTL=600
# Per-group cap, so keyword matching per message stays bounded.
MAX_FILTERS_PER_GROUP=200

# --- Health & alerting (defaults shown; all optional) ---
# Port for the /health liveness endpoint. docker-compose sets this per
# service (bot 8080, worker 8081) - only override for a bare-metal run.
HEALTH_PORT=8080
# Seconds the same fatal error stays deduped before it can alert again.
ALERT_COOLDOWN=900
